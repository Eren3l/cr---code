/* pages/mine/mine.wxss */
.page {
  padding-bottom: 30px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 12px;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  gap: 15px;
}

.user-avatar {
  width: 60px;
  height: 60px;
  border-radius: 30px;
  overflow: hidden;
  background-color: #EDF4FC;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 60px;
  height: 60px;
}

.avatar-placeholder {
  font-size: 30px;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 18px;
  font-weight: bold;
  display: block;
  margin-bottom: 4px;
}

/* 菜单 */
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  font-size: 15px;
}

.menu-item.danger {
  color: #FF4D4F;
}

.menu-arrow {
  color: #CCCCCC;
  font-size: 20px;
}

/* 身体数据 */
.body-data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #F0F0F0;
}

.body-date {
  font-size: 14px;
  font-weight: bold;
}

.body-data-item:last-child {
  border-bottom: none;
}
