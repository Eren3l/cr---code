<!-- pages/workout/workout.wxml -->
<view class="page">

  <!-- 日期 & 状态 -->
  <view class="card">
    <view class="date-header">
      <text class="date-text">📅 {{date}}</text>
      <text class="streak-text">今日已打卡 {{todayRecords.length}} 次</text>
    </view>
  </view>

  <!-- 快速打卡（模板） -->
  <view class="card" wx:if="{{templates.length > 0}}">
    <view class="section-title">⚡ 快速打卡</view>
    <scroll-view scroll-x class="template-scroll">
      <view class="template-item {{selectedType === item.type ? 'active' : ''}}"
            wx:for="{{templates}}"
            wx:key="id"
            data-template="{{item}}"
            bindtap="useTemplate">
        <text class="template-name">{{item.name}}</text>
        <text class="template-detail">{{item.type}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 运动类型选择 -->
  <view class="card">
    <view class="section-title">运动类型</view>
    <view class="tag-group">
      <view class="tag {{selectedType === item ? 'active' : ''}}"
            wx:for="{{workoutTypes}}"
            wx:key="*this"
            hover-class="tag-hover"
            data-type="{{item}}"
            bindtap="selectType">
        {{item}}
      </view>
      <view class="tag {{showCustomInput ? 'active' : ''}}"
            hover-class="tag-hover"
            data-type="自定义"
            bindtap="selectType">
        + 自定义
      </view>
    </view>

    <!-- 自定义类型输入 -->
    <view wx:if="{{showCustomInput}}" class="custom-type-box">
      <input class="input-field" placeholder="输入运动名称"
             value="{{customType}}" bindinput="onCustomTypeInput"
             focus="{{showCustomInput}}" />
      <button class="btn-primary" style="margin-top:10px" bindtap="confirmCustomType">确认</button>
    </view>
  </view>

  <!-- 训练部位 -->
  <view class="card">
    <view class="section-title">训练部位（可选）</view>
    <view class="tag-group">
      <view class="tag {{selectedBodyPart === item ? 'active' : ''}}"
            wx:for="{{bodyParts}}"
            wx:key="*this"
            hover-class="tag-hover"
            data-part="{{item}}"
            bindtap="selectBodyPart">
        {{item}}
      </view>
    </view>
  </view>

  <!-- 详细打卡表单 -->
  <view class="card">
    <view class="section-title">📝 训练详情（全部可选填）</view>

    <view class="form-row">
      <view class="form-half">
        <text class="form-label">组数</text>
        <input class="input-field" type="number" placeholder="组"
               value="{{form.sets}}" data-field="sets" bindinput="onFormInput" />
      </view>
      <view class="form-half">
        <text class="form-label">次数</text>
        <input class="input-field" type="number" placeholder="次"
               value="{{form.reps}}" data-field="reps" bindinput="onFormInput" />
      </view>
    </view>

    <view class="form-row">
      <view class="form-half">
        <text class="form-label">重量 (kg)</text>
        <input class="input-field" type="digit" placeholder="kg"
               value="{{form.weight}}" data-field="weight" bindinput="onFormInput" />
      </view>
      <view class="form-half">
        <text class="form-label">时长 (分钟)</text>
        <input class="input-field" type="number" placeholder="分钟"
               value="{{form.duration}}" data-field="duration" bindinput="onFormInput" />
      </view>
    </view>

    <view class="form-row">
      <view class="form-half">
        <text class="form-label">距离 (km)</text>
        <input class="input-field" type="digit" placeholder="km"
               value="{{form.distance}}" data-field="distance" bindinput="onFormInput" />
      </view>
      <view class="form-half">
        <text class="form-label">配速</text>
        <input class="input-field" placeholder="如 5'30''"
               value="{{form.pace}}" data-field="pace" bindinput="onFormInput" />
      </view>
    </view>

    <view class="form-row">
      <view class="form-half">
        <text class="form-label">心率</text>
        <input class="input-field" type="number" placeholder="bpm"
               value="{{form.heartRate}}" data-field="heartRate" bindinput="onFormInput" />
      </view>
      <view class="form-half">
        <text class="form-label">动作感受</text>
        <view class="feeling-group">
          <view class="tag {{form.feeling === '轻松' ? 'active' : ''}}"
                hover-class="tag-hover"
                data-feeling="轻松" bindtap="selectFeeling">轻松</view>
          <view class="tag {{form.feeling === '适中' ? 'active' : ''}}"
                hover-class="tag-hover"
                data-feeling="适中" bindtap="selectFeeling">适中</view>
          <view class="tag {{form.feeling === '吃力' ? 'active' : ''}}"
                hover-class="tag-hover"
                data-feeling="吃力" bindtap="selectFeeling">吃力</view>
        </view>
      </view>
    </view>

    <!-- 照片 -->
    <view class="form-section">
      <text class="form-label">📷 训练照片（可选）</text>
      <view class="photo-list">
        <view class="photo-item" wx:for="{{photos}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFill" class="photo-img" />
          <view class="photo-delete" data-index="{{index}}" bindtap="deletePhoto">✕</view>
        </view>
        <view class="photo-add" bindtap="choosePhoto" wx:if="{{photos.length < 3}}">
          <text>+</text>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-section">
      <text class="form-label">备注</text>
      <input class="input-field" placeholder="训练感受、心得..."
             value="{{form.note}}" data-field="note" bindinput="onFormInput" />
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="btn-group">
    <button class="btn-primary" bindtap="submitWorkout">✅ 打卡</button>
    <button class="btn-secondary" bindtap="saveAsTemplate">💾 保存为模板</button>
  </view>

  <!-- 今日记录 -->
  <view class="card" wx:if="{{todayRecords.length > 0}}">
    <view class="section-title">📋 今日记录</view>
    <view class="record-item" wx:for="{{todayRecords}}" wx:key="id">
      <view class="record-info">
        <text class="record-type">{{item.type}}</text>
        <text class="record-detail">
          <text wx:if="{{item.bodyPart}}">{{item.bodyPart}} · </text>
          <text wx:if="{{item.sets}}">{{item.sets}}组 </text>
          <text wx:if="{{item.reps}}">{{item.reps}}次 </text>
          <text wx:if="{{item.duration}}">{{item.duration}}分钟</text>
        </text>
        <text class="record-time text-muted">{{item.createdAt}}</text>
      </view>
      <view class="record-delete" data-id="{{item.id}}" bindtap="deleteRecord">删除</view>
    </view>
  </view>

  <view style="height: 30px;"></view>
</view>
