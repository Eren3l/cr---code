/* pages/template-manage/template-manage.wxss */
.page {
  padding-bottom: 30px;
}

.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 0;
}

.tpl-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tpl-info {
  flex: 1;
}

.tpl-name {
  font-size: 16px;
  font-weight: bold;
  display: block;
}

.tpl-detail {
  font-size: 13px;
  margin-top: 4px;
  display: block;
}

.tpl-actions {
  display: flex;
  align-items: center;
}

.tpl-delete {
  font-size: 20px;
  padding: 8px;
}

.btn-group {
  margin: 15px;
}
